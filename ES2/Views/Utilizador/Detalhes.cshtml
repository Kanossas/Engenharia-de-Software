@model ES2.Models.Utilizador

@{
    ViewData["Title"] = "Perfil";
    var tipo = Model.TipoUti switch
    {
        1 => "Administrador",
        3 => "Organizador",
        _ => "Utilizador"
    };
}

<section class="eh-account-page eh-account-page--profile">
    <div class="eh-account-shell">
        <a class="eh-account-back" asp-controller="Home" asp-action="Index">
            <i class="bi bi-arrow-left"></i>
            Voltar para eventos
        </a>

        <div class="eh-profile-layout">
            <div>
                <div class="eh-account-kicker">Area pessoal</div>
                <h1 class="eh-account-title">O Meu Perfil</h1>
                <p class="eh-account-subtitle">Consulta os dados ligados a tua conta Event Horizon.</p>

                <div class="eh-action-row">
                    <a class="eh-btn-primary" asp-controller="Utilizador" asp-action="EditarPerfil" asp-route-id="@Model.IdUti">
                        <i class="bi bi-pencil-square"></i>
                        Editar dados
                    </a>
                    <a class="eh-btn-secondary" asp-controller="Bilhete" asp-action="HistoricoCompras">
                        <i class="bi bi-cart3"></i>
                        Bilhetes
                    </a>
                </div>
            </div>

            <article class="eh-account-panel eh-account-panel--wide">
                <h2 class="eh-profile-card-title">Informacoes da conta</h2>

                <div class="eh-info-list">
                    <div class="eh-info-row">
                        <span class="eh-info-label"><i class="bi bi-person"></i> Nome</span>
                        <span class="eh-info-value">@Model.Nome</span>
                    </div>
                    <div class="eh-info-row">
                        <span class="eh-info-label"><i class="bi bi-envelope"></i> Email</span>
                        <span class="eh-info-value">@Model.Email</span>
                    </div>
                    <div class="eh-info-row">
                        <span class="eh-info-label"><i class="bi bi-phone"></i> Telemovel</span>
                        <span class="eh-info-value">@(string.IsNullOrWhiteSpace(Model.Telemovel) ? "Nao definido" : Model.Telemovel)</span>
                    </div>
                    <div class="eh-info-row">
                        <span class="eh-info-label"><i class="bi bi-stars"></i> Tipo</span>
                        <span class="eh-badge">@tipo</span>
                    </div>
                </div>
            </article>
        </div>
    </div>
</section>
