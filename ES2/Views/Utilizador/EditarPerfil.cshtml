@model ES2.DTOs.EditarPerfilDto

@{
    ViewData["Title"] = "Editar Perfil";
    var utilizadorId = ViewBag.UtilizadorId;
}

<section class="eh-account-page eh-account-page--profile">
    <div class="eh-account-shell eh-account-shell--center">
        <div class="eh-account-panel eh-account-panel--wide">
            <a class="eh-account-back" asp-controller="Utilizador" asp-action="Detalhes">
                <i class="bi bi-arrow-left"></i>
                Voltar ao perfil
            </a>

            <div class="eh-account-kicker">Area pessoal</div>
            <h1 class="eh-account-title eh-account-title--compact">Editar Perfil</h1>
            <p class="eh-account-subtitle">Atualiza os dados que aparecem associados a tua conta.</p>

            @if (TempData["Sucesso"] != null)
            {
                <div class="eh-alert alert alert-success mb-4" role="alert">
                    <i class="bi bi-check-circle me-2"></i>
                    @TempData["Sucesso"]
                    <span class="d-block mt-1">A redirecionar para a pagina inicial em 5 segundos...</span>
                </div>
            }

            <form asp-action="EditarPerfil" asp-route-id="@utilizadorId" method="post" class="eh-account-form">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="eh-alert validation-summary-errors"></div>

                <div class="eh-field">
                    <label asp-for="Nome"></label>
                    <div class="eh-input-wrap">
                        <i class="bi bi-person"></i>
                        <input asp-for="Nome" class="form-control" autocomplete="name" />
                    </div>
                    <span asp-validation-for="Nome" class="eh-validation"></span>
                </div>

                <div class="eh-field">
                    <label asp-for="Email"></label>
                    <div class="eh-input-wrap">
                        <i class="bi bi-envelope"></i>
                        <input asp-for="Email" class="form-control" type="email" autocomplete="email" />
                    </div>
                    <span asp-validation-for="Email" class="eh-validation"></span>
                </div>

                <div class="eh-field">
                    <label asp-for="Telemovel"></label>
                    <div class="eh-input-wrap">
                        <i class="bi bi-phone"></i>
                        <input asp-for="Telemovel" class="form-control" autocomplete="tel" />
                    </div>
                    <span asp-validation-for="Telemovel" class="eh-validation"></span>
                </div>

                <div class="eh-action-row">
                    <button type="submit" class="eh-btn-primary">
                        <i class="bi bi-check2"></i>
                        Guardar
                    </button>
                    <a class="eh-btn-secondary" asp-controller="Utilizador" asp-action="Detalhes">
                        Cancelar
                    </a>
                </div>
            </form>
        </div>
    </div>
</section>

@if (TempData["Sucesso"] != null)
{
    <script>
        setTimeout(function () {
            window.location.href = '/';
        }, 5000);
    </script>
}

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
