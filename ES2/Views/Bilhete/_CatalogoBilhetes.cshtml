@model IEnumerable<ES2.Models.BilhetesEvento>

@{
    var eventosInscritos = ViewBag.EventosInscritos as HashSet<int> ?? new HashSet<int>();
}

@if (Model.Any())
{
    <div class="row g-3">
        @foreach (var bilhete in Model)
        {
            var jaInscrito = eventosInscritos.Contains(bilhete.IdEvento);
            <div class="col-12 col-md-6 col-xl-4">
                <article class="card h-100 shadow-sm">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                            <h5 class="card-title mb-0">@bilhete.IdBilheteNavigation.Nome</h5>
                            <span class="badge text-bg-success">@bilhete.Preco.ToString("0.00") EUR</span>
                        </div>
                        <p class="fw-semibold mb-3">@bilhete.IdEventoNavigation.Nome</p>
                        <dl class="row mb-0 small">
                            <dt class="col-4">Tipo</dt>
                            <dd class="col-8">@(bilhete.IdBilheteNavigation.IdTipoNavigation?.Nome ?? "-")</dd>
                            <dt class="col-4">Data</dt>
                            <dd class="col-8">@(bilhete.IdEventoNavigation.Data?.ToString("dd/MM/yyyy") ?? "-")</dd>
                            <dt class="col-4">Hora</dt>
                            <dd class="col-8">@(bilhete.IdEventoNavigation.HoraInicio?.ToString("HH:mm") ?? "-")</dd>
                            <dt class="col-4">Local</dt>
                            <dd class="col-8">@(string.IsNullOrWhiteSpace(bilhete.IdEventoNavigation.Local) ? "-" : bilhete.IdEventoNavigation.Local)</dd>
                            <dt class="col-4">Stock</dt>
                            <dd class="col-8">@bilhete.QuantidadeDisponivel</dd>
                        </dl>
                        @if (jaInscrito)
                        {
                            <form asp-action="CancelarInscricao" method="post" class="mt-3">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@bilhete.IdBiEv" />
                                <button type="submit" class="btn btn-sm btn-danger">
                                    <i class="bi bi-x-circle"></i> Cancelar inscricao
                                </button>
                            </form>
                        }
                        else
                        {
                            <a asp-action="Checkout" asp-route-id="@bilhete.IdBiEv" class="btn btn-sm btn-success mt-3 @(bilhete.QuantidadeDisponivel <= 0 ? "disabled" : "")">
                                <i class="bi bi-credit-card"></i> Comprar
                            </a>
                        }
                    </div>
                </article>
            </div>
        }
    </div>
}
else
{
    <div class="text-center py-5">Nenhum bilhete encontrado.</div>
}
