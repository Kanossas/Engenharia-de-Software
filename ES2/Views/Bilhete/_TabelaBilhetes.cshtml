@model IEnumerable<ES2.Models.BilhetesEvento>

@if (Model.Any())
{
    @foreach (var bilhete in Model)
    {
        <tr>
            <td>@bilhete.IdEventoNavigation.Nome</td>
            <td>@bilhete.IdBilheteNavigation.Nome</td>
            <td>@(bilhete.IdBilheteNavigation.IdTipoNavigation?.Nome ?? "-")</td>
            <td>@(bilhete.IdEventoNavigation.Data?.ToString("dd/MM/yyyy") ?? "-")</td>
            <td>@(bilhete.IdEventoNavigation.HoraInicio?.ToString("HH:mm") ?? "-")</td>
            <td>@(string.IsNullOrWhiteSpace(bilhete.IdEventoNavigation.Local) ? "-" : bilhete.IdEventoNavigation.Local)</td>
            <td>@bilhete.Preco.ToString("0.00") EUR</td>
            <td class="text-end">
                <form asp-action="Inscrever" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@bilhete.IdBiEv" />
                    <input type="hidden" name="nome" value="@ViewBag.FiltroNome" />
                    <input type="hidden" name="data" value="@ViewBag.FiltroData" />
                    <input type="hidden" name="local" value="@ViewBag.FiltroLocal" />
                    <input type="hidden" name="idTipo" value="@ViewBag.FiltroTipo" />
                    <button type="submit" class="btn btn-sm btn-success">
                        <i class="bi bi-ticket-perforated"></i> Inscrever
                    </button>
                </form>
            </td>
        </tr>
    }
}
else
{
    <tr>
        <td colspan="8" class="text-center py-4">Nenhum bilhete encontrado.</td>
    </tr>
}
