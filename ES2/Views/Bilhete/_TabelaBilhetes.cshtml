@model IEnumerable<ES2.Models.BilhetesEvento>

@{
    var eventosInscritos = ViewBag.EventosInscritos as HashSet<int> ?? new HashSet<int>();
}

@if (Model.Any())
{
    @foreach (var bilhete in Model)
    {
        var jaInscrito = eventosInscritos.Contains(bilhete.IdEvento);
        <tr>
            <td>@bilhete.IdEventoNavigation.Nome</td>
            <td>@bilhete.IdBilheteNavigation.Nome</td>
            <td>@(bilhete.IdBilheteNavigation.IdTipoNavigation?.Nome ?? "-")</td>
            <td>@(bilhete.IdEventoNavigation.Data?.ToString("dd/MM/yyyy") ?? "-")</td>
            <td>@(bilhete.IdEventoNavigation.HoraInicio?.ToString("HH:mm") ?? "-")</td>
            <td>@(string.IsNullOrWhiteSpace(bilhete.IdEventoNavigation.Local) ? "-" : bilhete.IdEventoNavigation.Local)</td>
            <td>@bilhete.Preco.ToString("0.00") EUR</td>
            <td>@bilhete.QuantidadeDisponivel</td>
            <td class="text-end">
                @if (jaInscrito)
                {
                    <form asp-action="CancelarInscricao" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@bilhete.IdBiEv" />
                        <button type="submit" class="btn btn-sm btn-danger"
                                onclick="return confirm('Tens a certeza que queres cancelar a inscrição neste evento?')">
                            <i class="bi bi-x-circle"></i> Cancelar Inscrição
                        </button>
                    </form>
                }
                else
                {
                    <a asp-action="Checkout" asp-route-id="@bilhete.IdBiEv" class="btn btn-sm btn-success @(bilhete.QuantidadeDisponivel <= 0 ? "disabled" : "")">
                        <i class="bi bi-credit-card"></i> Comprar
                    </a>
                }
            </td>
        </tr>
    }
}
else
{
    <tr>
        <td colspan="9" class="text-center py-4">Nenhum bilhete encontrado.</td>
    </tr>
}
