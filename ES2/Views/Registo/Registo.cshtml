@model ES2.Models.RegistoModel

@{
    ViewData["Title"] = "Criar Conta";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-header bg-primary text-white text-center">
                    <h4>Registo de Utilizador</h4>
                </div>
                <div class="card-body">
                    <form asp-action="Registo" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                        <div class="mb-3">
                            <label class="form-label">Nome Completo</label>
                            <input asp-for="Nome" class="form-control" placeholder="Ex: Hugo Silva" />
                            <span asp-validation-for="Nome" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Email</label>
                            <input asp-for="Email" class="form-control" type="email" placeholder="email@exemplo.com" />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Palavra-passe</label>
                            <input asp-for="Password" class="form-control" type="password" />
                            <span asp-validation-for="Password" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Telemóvel</label>
                            <input asp-for="Telemovel" class="form-control" placeholder="912345678" />
                            <span asp-validation-for="Telemovel" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Código Postal</label>
                            <input asp-for="CodigoPostalInput" class="form-control" placeholder="4000-000" />
                            <span asp-validation-for="CodigoPostalInput" class="text-danger"></span>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-success">Finalizar Registo</button>
                            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}