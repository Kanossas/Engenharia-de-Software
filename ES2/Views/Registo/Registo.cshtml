@model ES2.Models.RegistoModel

@{
    ViewData["Title"] = "Registo";
}

<section class="eh-account-page">
    <div class="eh-account-shell eh-account-shell--center">
        <div class="eh-account-panel">
            <a class="eh-account-back" asp-controller="Home" asp-action="Index">
                <i class="bi bi-arrow-left"></i>
                Voltar
            </a>

            <div class="eh-account-kicker">Nova identidade</div>
            <h1 class="eh-account-title eh-account-title--compact">Cria a tua conta</h1>
            <p class="eh-account-subtitle">Preenche os dados para acederes ao universo Event Horizon.</p>

            <form asp-action="Registo" method="post" class="eh-account-form">
                <div asp-validation-summary="ModelOnly" class="eh-alert validation-summary-errors"></div>

                <div class="eh-field">
                    <label asp-for="Nome"></label>
                    <div class="eh-input-wrap">
                        <i class="bi bi-person"></i>
                        <input asp-for="Nome" class="form-control" placeholder="Nome completo" autocomplete="name" />
                    </div>
                    <span asp-validation-for="Nome" class="eh-validation"></span>
                </div>

                <div class="eh-field">
                    <label asp-for="Email"></label>
                    <div class="eh-input-wrap">
                        <i class="bi bi-envelope"></i>
                        <input asp-for="Email" class="form-control" type="email" placeholder="teu@email.com" autocomplete="email" />
                    </div>
                    <span asp-validation-for="Email" class="eh-validation"></span>
                </div>

                <div class="eh-field">
                    <label asp-for="Password"></label>
                    <div class="eh-input-wrap">
                        <i class="bi bi-lock"></i>
                        <input asp-for="Password" class="form-control" type="password" placeholder="********" autocomplete="new-password" />
                    </div>
                    <span asp-validation-for="Password" class="eh-validation"></span>
                </div>

                <div class="eh-field">
                    <label asp-for="Telemovel"></label>
                    <div class="eh-input-wrap">
                        <i class="bi bi-phone"></i>
                        <input asp-for="Telemovel" class="form-control" placeholder="Telemovel" autocomplete="tel" />
                    </div>
                    <span asp-validation-for="Telemovel" class="eh-validation"></span>
                </div>

                <div class="eh-field">
                    <label asp-for="CodigoPostalInput"></label>
                    <div class="eh-input-wrap">
                        <i class="bi bi-geo-alt"></i>
                        <input asp-for="CodigoPostalInput" class="form-control" placeholder="Codigo postal" autocomplete="postal-code" />
                    </div>
                    <span asp-validation-for="CodigoPostalInput" class="eh-validation"></span>
                </div>

                <button type="submit" class="eh-btn-primary">
                    Registar
                    <i class="bi bi-arrow-right"></i>
                </button>
            </form>

            <p class="eh-auth-foot">
                Ja tens conta?
                <a asp-controller="Login" asp-action="Index">Entrar</a>
            </p>
        </div>
    </div>
</section>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
