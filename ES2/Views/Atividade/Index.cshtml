@model IEnumerable<ES2.Models.Atividade>

@{
    ViewData["Title"] = "Atividades";
    var categorias = ViewBag.Categorias as IEnumerable<ES2.Models.Categoria> ?? Enumerable.Empty<ES2.Models.Categoria>();
    var eventos = ViewBag.Eventos as IEnumerable<ES2.Models.Evento> ?? Enumerable.Empty<ES2.Models.Evento>();
}

<div class="d-flex justify-content-between align-items-center mt-4 mb-4">
    <div>
        <h2 class="mb-1">Atividades</h2>
        <p class="text-light mb-0">Lista das atividades ja criadas no sistema.</p>
    </div>
</div>

<div class="d-flex justify-content-start mb-3">
    <div class="btn-group btn-group-sm view-toggle" role="group" aria-label="Alternar visualizacao de atividades">
        <button type="button" class="btn btn-outline-light active" data-view-mode="tabela" title="Vista em lista">
            <i class="bi bi-list-ul"></i>
        </button>
        <button type="button" class="btn btn-outline-light" data-view-mode="catalogo" title="Vista em catalogo">
            <i class="bi bi-grid-3x3-gap"></i>
        </button>
    </div>
</div>

@if (TempData["Sucesso"] != null)
{
    <div class="alert alert-success">@TempData["Sucesso"]</div>
}

@if (TempData["Erro"] != null)
{
    <div class="alert alert-danger">@TempData["Erro"]</div>
}

<div class="card shadow mb-4">
    <div class="card-body">
        <form method="get" asp-action="Index" id="formPesquisa" class="row g-3 align-items-end">
            <div class="col-md-3">
                <label class="form-label">Evento</label>
                <select name="idEvento" id="filtroEvento" class="form-select">
                    <option value="">Todas</option>
                    @foreach (var evento in eventos)
                    {
                        <option value="@evento.IdEvento" selected="@(ViewBag.FiltroEvento != null && (int)ViewBag.FiltroEvento == evento.IdEvento)">@evento.Nome</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label">Nome</label>
                <input type="text" name="nome" id="filtroNome" class="form-control" placeholder="Pesquisar por nome..." value="@ViewBag.FiltroNome" autocomplete="off" />
            </div>
            <div class="col-md-2">
                <label class="form-label">Local</label>
                <input type="text" name="local" id="filtroLocal" class="form-control" placeholder="Pesquisar por local..." value="@ViewBag.FiltroLocal" autocomplete="off" />
            </div>
            <div class="col-md-2">
                <label class="form-label">Capacidade minima</label>
                <input type="number" name="capacidade" id="filtroCapacidade" class="form-control" placeholder="Capacidade..." value="@ViewBag.FiltroCapacidade" min="0" />
            </div>
            <div class="col-md-2">
                <label class="form-label">Categoria</label>
                <select name="idCategoria" id="filtroCategoria" class="form-select">
                    <option value="">Todas</option>
                    @foreach (var categoria in categorias)
                    {
                        <option value="@categoria.IdCategoria" selected="@(ViewBag.FiltroCategoria != null && (int)ViewBag.FiltroCategoria == categoria.IdCategoria)">@categoria.Nome</option>
                    }
                </select>
            </div>
            <div class="col-md-2 d-flex gap-2">
                <button type="submit" class="btn btn-primary w-100">Pesquisar</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Limpar</a>
            </div>
        </form>
    </div>
</div>

<div id="resultadoAtividades">
    <partial name="_ResultadosAtividades" model="Model" />
</div>

@section Scripts {
    <script>
        const resultadoAtividades = document.getElementById('resultadoAtividades');
        const botoesVista = document.querySelectorAll('.view-toggle [data-view-mode]');
        const inputs = ['filtroNome', 'filtroLocal', 'filtroCapacidade'];
        const selects = ['filtroCategoria', 'filtroEvento'];
        const storageKey = 'atividades-view-mode';
        let debounce;

        function aplicarModoVisualizacao() {
            const modo = sessionStorage.getItem(storageKey) || 'tabela';
            const tabela = document.getElementById('vistaTabelaAtividades');
            const catalogo = document.getElementById('vistaCatalogoAtividades');

            if (tabela && catalogo) {
                tabela.classList.toggle('d-none', modo !== 'tabela');
                catalogo.classList.toggle('d-none', modo !== 'catalogo');
            }

            botoesVista.forEach(botao => {
                botao.classList.toggle('active', botao.dataset.viewMode === modo);
            });
        }

        function pesquisar() {
            const params = new URLSearchParams({
                nome: document.getElementById('filtroNome').value,
                capacidade: document.getElementById('filtroCapacidade').value,
                local: document.getElementById('filtroLocal').value,
                idCategoria: document.getElementById('filtroCategoria').value,
                idEvento: document.getElementById('filtroEvento').value
            });

            fetch('@Url.Action("Pesquisar", "Atividade")?' + params)
                .then(r => r.text())
                .then(html => {
                    resultadoAtividades.innerHTML = html;
                    aplicarModoVisualizacao();
                });
        }

        inputs.forEach(id => {
            document.getElementById(id).addEventListener('input', () => {
                clearTimeout(debounce);
                debounce = setTimeout(pesquisar, 300);
            });
        });

        selects.forEach(id => {
            document.getElementById(id).addEventListener('change', pesquisar);
        });

        botoesVista.forEach(botao => {
            botao.addEventListener('click', () => {
                sessionStorage.setItem(storageKey, botao.dataset.viewMode);
                aplicarModoVisualizacao();
            });
        });

        aplicarModoVisualizacao();
    </script>
}
