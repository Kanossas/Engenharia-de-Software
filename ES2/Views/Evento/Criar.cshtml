@model ES2.DTOs.CriarEventoDto

@{
    var emEdicao = ViewBag.EmEdicao is true;
    ViewData["Title"] = ViewBag.TituloFormulario ?? "Criar Evento";
    var categorias = ViewBag.Categorias as IEnumerable<ES2.Models.Categoria> ?? Enumerable.Empty<ES2.Models.Categoria>();
    var acaoFormulario = (string?)ViewBag.FormAction ?? "Criar";
    int? eventoId = ViewBag.EventoId as int?;
    var categoriaSelecionada = Model.IdCategoria?.ToString();
    var mostrarNovaCategoria = !string.IsNullOrWhiteSpace(Model.NovaCategoria);
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow">
                <div class="card-header bg-primary text-white text-center">
                    <h4>@ViewData["Title"]</h4>
                </div>
                <div class="card-body">
                    <form asp-action="@acaoFormulario" asp-route-id="@eventoId" method="post">
                        @if (Model.IdEvento.HasValue)
                        {
                            <input asp-for="IdEvento" type="hidden" />
                        }

                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="row">
                            <div class="col-md-8 mb-3">
                                <label asp-for="Nome" class="form-label"></label>
                                <input asp-for="Nome" class="form-control" placeholder="Ex: Conferencia de Tecnologia" />
                                <span asp-validation-for="Nome" class="text-danger"></span>
                            </div>

                            <div class="col-md-4 mb-3">
                                <label asp-for="Capacidade" class="form-label">Capacidade Maxima</label>
                                <input asp-for="Capacidade" class="form-control" type="number" min="1" />
                                <span asp-validation-for="Capacidade" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-4 mb-3">
                                <label asp-for="Data" class="form-label"></label>
                                <input asp-for="Data" class="form-control" type="date" />
                                <span asp-validation-for="Data" class="text-danger"></span>
                            </div>

                            <div class="col-md-4 mb-3">
                                <label asp-for="HoraInicio" class="form-label">Hora</label>
                                <input asp-for="HoraInicio" class="form-control" type="time" />
                                <span asp-validation-for="HoraInicio" class="text-danger"></span>
                            </div>

                            <div class="col-md-4 mb-3">
                                <label asp-for="Preco" class="form-label">Preco</label>
                                <input asp-for="Preco" class="form-control" type="number" min="0" step="0.01" />
                                <span asp-validation-for="Preco" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-8 mb-3">
                                <label asp-for="Local" class="form-label"></label>
                                <input asp-for="Local" class="form-control" placeholder="Ex: Porto, Centro de Congressos" />
                                <span asp-validation-for="Local" class="text-danger"></span>
                            </div>

                            <div class="col-md-4 mb-3">
                                <label class="form-label">Categoria</label>
                                <input type="hidden" asp-for="IdCategoria" id="hiddenIdCategoria" />
                                <select class="form-select" id="selectCategoria">
                                    <option value="" selected="@(string.IsNullOrWhiteSpace(categoriaSelecionada) && !mostrarNovaCategoria)">Sem categoria</option>
                                    @foreach (var cat in categorias)
                                    {
                                        <option value="@cat.IdCategoria" selected="@(categoriaSelecionada == cat.IdCategoria.ToString())">@cat.Nome</option>
                                    }
                                    <option value="__nova__" selected="@mostrarNovaCategoria">+ Adicionar categoria</option>
                                </select>
                                <input asp-for="NovaCategoria" id="inputNovaCategoria" class="form-control mt-2"
                                       placeholder="Nome da nova categoria" style="display:@(mostrarNovaCategoria ? "block" : "none")" />
                                <span asp-validation-for="NovaCategoria" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Descricao" class="form-label"></label>
                            <textarea asp-for="Descricao" class="form-control" rows="5" placeholder="Descreve o evento"></textarea>
                            <span asp-validation-for="Descricao" class="text-danger"></span>
                        </div>

                        <div class="d-flex gap-2 justify-content-end">
                            <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                            <button type="submit" class="btn @(emEdicao ? "btn-primary" : "btn-success")">@ViewBag.TextoBotaoSubmeter</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        const select = document.getElementById('selectCategoria');
        const input = document.getElementById('inputNovaCategoria');
        const hidden = document.getElementById('hiddenIdCategoria');

        function sincronizarCategoria() {
            if (select.value === '__nova__') {
                input.style.display = 'block';
                input.required = true;
                hidden.value = '';
                return;
            }

            input.style.display = 'none';
            input.required = false;
            input.value = '';
            hidden.value = select.value;
        }

        sincronizarCategoria();
        select.addEventListener('change', sincronizarCategoria);
    </script>
}
