@model ES2.DTOs.CriarEventoDto

@{
    ViewData["Title"] = "Criar Evento";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow">
                <div class="card-header bg-primary text-white text-center">
                    <h4>Criar Evento</h4>
                </div>
                <div class="card-body">
                    <form asp-action="Criar" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="row">
                            <div class="col-md-8 mb-3">
                                <label asp-for="Nome" class="form-label"></label>
                                <input asp-for="Nome" class="form-control" placeholder="Ex: Conferência de Tecnologia" />
                                <span asp-validation-for="Nome" class="text-danger"></span>
                            </div>

                            <div class="col-md-4 mb-3">
                                <label asp-for="Capacidade" class="form-label">Capacidade Máxima</label>
                                <input asp-for="Capacidade" class="form-control" type="number" min="1" />
                                <span asp-validation-for="Capacidade" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-4 mb-3">
                                <label asp-for="Data" class="form-label"></label>
                                <input asp-for="Data" class="form-control" type="date" />
                                <span asp-validation-for="Data" class="text-danger"></span>
                            </div>

                            <div class="col-md-4 mb-3">
                                <label asp-for="HoraInicio" class="form-label">Hora</label>
                                <input asp-for="HoraInicio" class="form-control" type="time" />
                                <span asp-validation-for="HoraInicio" class="text-danger"></span>
                            </div>

                            <div class="col-md-4 mb-3">
                                <label asp-for="Preco" class="form-label">Preço</label>
                                <input asp-for="Preco" class="form-control" type="number" min="0" step="0.01" />
                                <span asp-validation-for="Preco" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Local" class="form-label"></label>
                            <input asp-for="Local" class="form-control" placeholder="Ex: Porto, Centro de Congressos" />
                            <span asp-validation-for="Local" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Descricao" class="form-label"></label>
                            <textarea asp-for="Descricao" class="form-control" rows="5" placeholder="Descreve o evento"></textarea>
                            <span asp-validation-for="Descricao" class="text-danger"></span>
                        </div>

                        <div class="d-flex gap-2 justify-content-end">
                            <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                            <button type="submit" class="btn btn-success">Criar Evento</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
