@model IEnumerable<ES2.Models.Evento>

@{
    ViewData["Title"] = "Eventos";
    var categorias = ViewBag.Categorias as IEnumerable<ES2.Models.Categoria> ?? Enumerable.Empty<ES2.Models.Categoria>();
}

<div class="d-flex justify-content-between align-items-center mt-4 mb-4">
    <div>
        <h2 class="mb-1">Eventos</h2>
        <p class="text-muted mb-0">Explora os eventos disponiveis e entra no detalhe para comprar o teu bilhete.</p>
    </div>
</div>

@if (TempData["Sucesso"] != null)
{
    <div class="alert alert-success">@TempData["Sucesso"]</div>
}

@if (TempData["Erro"] != null)
{
    <div class="alert alert-danger">@TempData["Erro"]</div>
}

<div class="d-flex justify-content-start mb-3">
    <div class="btn-group btn-group-sm view-toggle" role="group" aria-label="Alternar visualizacao de eventos">
        <button type="button" class="btn btn-outline-light active" data-view-mode="tabela" title="Vista em lista">
            <i class="bi bi-list-ul"></i>
        </button>
        <button type="button" class="btn btn-outline-light" data-view-mode="catalogo" title="Vista em catalogo">
            <i class="bi bi-grid-3x3-gap"></i>
        </button>
    </div>
</div>

<div class="card shadow mb-4">
    <div class="card-body">
        <form method="get" asp-action="Index" id="formPesquisaEventos" class="row g-3 align-items-end">
            <div class="col-md-3">
                <label class="form-label">Nome</label>
                <input type="text" name="nome" id="filtroNome" class="form-control" placeholder="Pesquisar por nome..." value="@ViewBag.FiltroNome" autocomplete="off" />
            </div>
            <div class="col-md-2">
                <label class="form-label">Data</label>
                <input type="date" name="data" id="filtroData" class="form-control" value="@ViewBag.FiltroData" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Local</label>
                <input type="text" name="local" id="filtroLocal" class="form-control" placeholder="Pesquisar por local..." value="@ViewBag.FiltroLocal" autocomplete="off" />
            </div>
            <div class="col-md-2">
                <label class="form-label">Categoria</label>
                <select name="idCategoria" id="filtroCategoria" class="form-select">
                    <option value="">Todas</option>
                    @foreach (var categoria in categorias)
                    {
                        <option value="@categoria.IdCategoria" selected="@(ViewBag.FiltroCategoria != null && (int)ViewBag.FiltroCategoria == categoria.IdCategoria)">@categoria.Nome</option>
                    }
                </select>
            </div>
            <div class="col-md-2 d-flex gap-2">
                <button type="submit" class="btn btn-primary w-100">Pesquisar</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Limpar</a>
            </div>
        </form>
    </div>
</div>

<div id="resultadoEventos">
    <partial name="_ResultadosEventos" model="Model" />
</div>

@section Scripts {
    <script>
        const resultadoEventos = document.getElementById('resultadoEventos');
        const botoesVistaEventos = document.querySelectorAll('.view-toggle [data-view-mode]');
        const storageKeyEventos = 'eventos-view-mode';
        let debounceEventos;

        function aplicarModoVisualizacaoEventos() {
            const modo = sessionStorage.getItem(storageKeyEventos) || 'tabela';
            const tabela = document.getElementById('vistaTabelaEventos');
            const catalogo = document.getElementById('vistaCatalogoEventos');

            if (tabela && catalogo) {
                tabela.classList.toggle('d-none', modo !== 'tabela');
                catalogo.classList.toggle('d-none', modo !== 'catalogo');
            }

            botoesVistaEventos.forEach(botao => {
                botao.classList.toggle('active', botao.dataset.viewMode === modo);
            });
        }

        function pesquisarEventos() {
            const params = new URLSearchParams({
                nome: document.getElementById('filtroNome').value,
                data: document.getElementById('filtroData').value,
                local: document.getElementById('filtroLocal').value,
                idCategoria: document.getElementById('filtroCategoria').value
            });

            fetch('@Url.Action("Pesquisar", "Evento")?' + params)
                .then(r => r.text())
                .then(html => {
                    resultadoEventos.innerHTML = html;
                    aplicarModoVisualizacaoEventos();
                });
        }

        ['filtroNome', 'filtroLocal'].forEach(id => {
            document.getElementById(id).addEventListener('input', () => {
                clearTimeout(debounceEventos);
                debounceEventos = setTimeout(pesquisarEventos, 300);
            });
        });

        ['filtroData', 'filtroCategoria'].forEach(id => {
            document.getElementById(id).addEventListener('change', pesquisarEventos);
        });

        botoesVistaEventos.forEach(botao => {
            botao.addEventListener('click', () => {
                sessionStorage.setItem(storageKeyEventos, botao.dataset.viewMode);
                aplicarModoVisualizacaoEventos();
            });
        });

        aplicarModoVisualizacaoEventos();
    </script>
}
