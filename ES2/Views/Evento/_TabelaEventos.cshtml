@model IEnumerable<ES2.Models.Evento>

@if (Model.Any())
{
    @foreach (var evento in Model)
    {
        <tr data-evento-id="@evento.IdEvento" style="cursor: pointer;">
            <td>@evento.Nome</td>
            <td>@(evento.Data?.ToString("dd/MM/yyyy") ?? "-")</td>
            <td>@(evento.HoraInicio?.ToString("HH:mm") ?? "-")</td>
            <td>@(string.IsNullOrWhiteSpace(evento.Local) ? "-" : evento.Local)</td>
            <td>@(evento.IdCategoriaNavigation?.Nome ?? "-")</td>
            <td>@(evento.CapMax?.ToString() ?? "-")</td>
            <td class="text-end">
                <a asp-action="Detalhes" asp-route-id="@evento.IdEvento" class="btn btn-sm btn-primary">
                    <i class="bi bi-ticket-perforated"></i> Ver Evento
                </a>
                <a asp-action="Participantes" asp-route-id="@evento.IdEvento" class="btn btn-sm btn-outline-info">
                    <i class="bi bi-people"></i> Participantes
                </a>
            </td>
        </tr>
    }
}
else
{
    <tr>
        <td colspan="7" class="text-center py-4">Nenhum evento encontrado.</td>
    </tr>
}
