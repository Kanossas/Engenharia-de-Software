@model ES2.DTOs.RelatorioAdminDto
@{
    ViewData["Title"] = "Relatórios";
    var meses = Model.EventosPorMes.Select(e => $"\"{e.NomeMes}\"").ToList();
    var totaisMes = Model.EventosPorMes.Select(e => e.TotalEventos.ToString()).ToList();
    var categorias = Model.EventosPorCategoria.Select(e => $"\"{e.Categoria}\"").ToList();
    var totaisCat = Model.EventosPorCategoria.Select(e => e.TotalEventos.ToString()).ToList();
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-bar-chart-line"></i> Relatórios de Administração</h2>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card text-white bg-primary shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <i class="bi bi-calendar-event fs-1"></i>
                <div>
                    <div class="fs-2 fw-bold">@Model.TotalEventos</div>
                    <div class="small">Total de Eventos</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-white bg-success shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <i class="bi bi-people fs-1"></i>
                <div>
                    <div class="fs-2 fw-bold">@Model.TotalUtilizadores</div>
                    <div class="small">Utilizadores Registados</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-white bg-warning shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <i class="bi bi-ticket-perforated fs-1"></i>
                <div>
                    <div class="fs-2 fw-bold">@Model.TotalInscricoes</div>
                    <div class="small">Total de Inscrições</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-white bg-info shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <i class="bi bi-graph-up-arrow fs-1"></i>
                <div>
                    <div class="fs-2 fw-bold">@Model.MediaEventosPorMes</div>
                    <div class="small">Média de Eventos por Mês</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-white bg-secondary shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <i class="bi bi-person-check fs-1"></i>
                <div>
                    <div class="fs-2 fw-bold">@Model.MediaParticipantesPorEvento</div>
                    <div class="small">Média de Participantes por Evento</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-white bg-danger shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <i class="bi bi-currency-euro fs-1"></i>
                <div>
                    <div class="fs-2 fw-bold">@Model.ReceitaTotal.ToString("F2") €</div>
                    <div class="small">Receita Total</div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-lg-8">
        <div class="card shadow-sm">
            <div class="card-header fw-semibold">
                <i class="bi bi-bar-chart"></i> Eventos por Mês
            </div>
            <div class="card-body">
                @if (Model.EventosPorMes.Any())
                {
                    <canvas id="graficoEventosMes" height="100"></canvas>
                }
                else
                {
                    <p class="text-muted mb-0">Sem dados disponíveis.</p>
                }
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card shadow-sm">
            <div class="card-header fw-semibold">
                <i class="bi bi-pie-chart"></i> Eventos por Categoria
            </div>
            <div class="card-body">
                @if (Model.EventosPorCategoria.Any())
                {
                    <canvas id="graficoCategoria" height="200"></canvas>
                }
                else
                {
                    <p class="text-muted mb-0">Sem dados disponíveis.</p>
                }
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-7">
        <div class="card shadow-sm">
            <div class="card-header fw-semibold">
                <i class="bi bi-table"></i> Detalhe: Eventos por Mês
            </div>
            <div class="card-body p-0">
                @if (Model.EventosPorMes.Any())
                {
                    <table class="table table-striped table-hover mb-0">
                        <thead class="table-dark">
                        <tr>
                            <th>Mês</th>
                            <th class="text-center">Nº de Eventos</th>
                        </tr>
                        </thead>
                        <tbody>
                        @foreach (var item in Model.EventosPorMes)
                        {
                            <tr>
                                <td>@item.NomeMes</td>
                                <td class="text-center">@item.TotalEventos</td>
                            </tr>
                        }
                        </tbody>
                        <tfoot class="table-secondary fw-semibold">
                        <tr>
                            <td>Média</td>
                            <td class="text-center">@Model.MediaEventosPorMes</td>
                        </tr>
                        </tfoot>
                    </table>
                }
                else
                {
                    <p class="text-muted p-3 mb-0">Sem dados disponíveis.</p>
                }
            </div>
        </div>
    </div>
    <div class="col-lg-5">
        <div class="card shadow-sm">
            <div class="card-header fw-semibold">
                <i class="bi bi-table"></i> Detalhe: Eventos por Categoria
            </div>
            <div class="card-body p-0">
                @if (Model.EventosPorCategoria.Any())
                {
                    <table class="table table-striped table-hover mb-0">
                        <thead class="table-dark">
                        <tr>
                            <th>Categoria</th>
                            <th class="text-center">Nº de Eventos</th>
                        </tr>
                        </thead>
                        <tbody>
                        @foreach (var item in Model.EventosPorCategoria)
                        {
                            <tr>
                                <td>@item.Categoria</td>
                                <td class="text-center">@item.TotalEventos</td>
                            </tr>
                        }
                        </tbody>
                    </table>
                }
                else
                {
                    <p class="text-muted p-3 mb-0">Sem dados disponíveis.</p>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script>
        @if (Model.EventosPorMes.Any())
        {
            <text>
            new Chart(document.getElementById('graficoEventosMes'), {
                type: 'bar',
                data: {
                    labels: [@Html.Raw(string.Join(",", meses))],
                    datasets: [{
                        label: 'Eventos',
                        data: [@string.Join(",", totaisMes)],
                        backgroundColor: 'rgba(13, 110, 253, 0.7)',
                        borderColor: 'rgba(13, 110, 253, 1)',
                        borderWidth: 1
                    }]
                },
                options: {
                    responsive: true,
                    plugins: { legend: { display: false } },
                    scales: { y: { beginAtZero: true, ticks: { stepSize: 1 } } }
                }
            });
            </text>
        }

        @if (Model.EventosPorCategoria.Any())
        {
            <text>
            new Chart(document.getElementById('graficoCategoria'), {
                type: 'doughnut',
                data: {
                    labels: [@Html.Raw(string.Join(",", categorias))],
                    datasets: [{
                        data: [@string.Join(",", totaisCat)],
                        backgroundColor: [
                            'rgba(13,110,253,0.8)', 'rgba(25,135,84,0.8)', 'rgba(255,193,7,0.8)',
                            'rgba(220,53,69,0.8)', 'rgba(13,202,240,0.8)', 'rgba(108,117,125,0.8)',
                            'rgba(111,66,193,0.8)', 'rgba(253,126,20,0.8)'
                        ]
                    }]
                },
                options: {
                    responsive: true,
                    plugins: { legend: { position: 'bottom' } }
                }
            });
            </text>
        }
    </script>
}
